<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Development signing entitlement. Remove or disable for production release builds. -->
	<key>com.apple.security.get-task-allow</key>
	<true/>
	<!-- Restricted entitlement: requires Apple approval on the selected developer team/profile. -->
	<key>com.apple.developer.hid.virtual.device</key>
	<true/>
</dict>
</plist>
